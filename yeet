#!/usr/bin/env bash
set -euo pipefail

# ──────────────────────────────────────────────
# yeet — Granola transcript → shareable link
# Backends: gist (default) | jotbird
#
# Granola access goes through the official Granola MCP server
# (https://mcp.granola.ai/mcp) via a small Node helper that handles
# the OAuth browser sign-in and caches the token under ~/.config/yeet.
#
# By default yeet publishes the meeting's notes + AI summary (works on the
# free Granola plan). Raw transcripts (--transcript) are paid-plan-only.
#
# Usage:
#   yeet              # pick a meeting, publish notes+summary via gist
#   yeet --jotbird    # publish via jotbird
#   yeet --transcript # publish the raw transcript (paid Granola plan only)
#   yeet --limit 50   # show more meetings
#   YEET_BACKEND=jotbird yeet   # env override
# ──────────────────────────────────────────────

LIMIT="${YEET_LIMIT:-20}"
BACKEND="${YEET_BACKEND:-gist}"
CONTENT="${YEET_CONTENT:-notes}"   # notes | transcript
# Was the content type explicitly chosen (flag/env)? If not, we ask interactively.
CONTENT_SET=0
[[ -n "${YEET_CONTENT:-}" ]] && CONTENT_SET=1

# ── Argument parsing ──
while [[ $# -gt 0 ]]; do
  case "$1" in
    --jotbird|-j)    BACKEND="jotbird"; shift ;;
    --gist|-g)       BACKEND="gist"; shift ;;
    --notes|-n)      CONTENT="notes"; CONTENT_SET=1; shift ;;
    --transcript|-t) CONTENT="transcript"; CONTENT_SET=1; shift ;;
    --limit|-l)      LIMIT="$2"; shift 2 ;;
    --help|-h)
      echo "Usage: yeet [--gist|-g] [--jotbird|-j] [--notes|-n|--transcript|-t] [--limit|-l N]"
      echo ""
      echo "  --gist, -g        Publish via GitHub Gist (default)"
      echo "  --jotbird, -j     Publish via Jotbird"
      echo "  --notes, -n       Publish meeting notes + AI summary (free plan)"
      echo "  --transcript, -t  Publish the raw transcript (premium / paid Granola plan)"
      echo "  --limit, -l N     Number of meetings to show (default: 20)"
      echo ""
      echo "  With no --notes/--transcript flag, yeet asks which to publish."
      echo "  Env: YEET_BACKEND=gist|jotbird  YEET_LIMIT=N  YEET_CONTENT=notes|transcript"
      exit 0
      ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

# ── Colors ──
bold="\033[1m"
green="\033[32m"
red="\033[31m"
cyan="\033[36m"
yellow="\033[33m"
reset="\033[0m"

info()  { printf "${cyan}▸${reset} %s\n" "$*"; }
ok()    { printf "${green}✓${reset} %s\n" "$*"; }
warn()  { printf "${yellow}⚠${reset} %s\n" "$*"; }
fail()  { printf "${red}✗${reset} %s\n" "$*" >&2; exit 1; }

# ── Locate the Granola MCP helper ──
# Order: env override → next to this script (dev/repo) → ~/.config/yeet
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HELPER="${YEET_MCP_HELPER:-}"
if [[ -z "$HELPER" ]]; then
  for cand in "$SCRIPT_DIR/granola-mcp.mjs" "$HOME/.config/yeet/granola-mcp.mjs"; do
    [[ -f "$cand" ]] && HELPER="$cand" && break
  done
fi
[[ -z "$HELPER" || ! -f "$HELPER" ]] && \
  fail "Granola MCP helper (granola-mcp.mjs) not found. Re-run the installer."
HELPER_DIR="$(cd "$(dirname "$HELPER")" && pwd)"

# ── Dependency check ──
command -v node &>/dev/null || fail "'node' not found. Install Node.js (brew install node)"
command -v npm  &>/dev/null || fail "'npm' not found. Install Node.js (brew install node)"
command -v fzf  &>/dev/null || fail "'fzf' not found. brew install fzf"
command -v python3 &>/dev/null || fail "'python3' not found. brew install python3"

if [[ "$BACKEND" == "gist" ]]; then
  command -v gh &>/dev/null || fail "'gh' not found. brew install gh"
else
  command -v jotbird &>/dev/null || fail "'jotbird' not found. Install it first."
fi

# ── Ensure the helper's MCP dependency is installed (one-time) ──
if [[ ! -d "$HELPER_DIR/node_modules/@modelcontextprotocol/sdk" ]]; then
  info "Installing Granola MCP client (one-time)..."
  ( cd "$HELPER_DIR" && npm install --silent ) \
    || fail "Failed to install MCP client deps in $HELPER_DIR"
fi

granola_mcp() { node "$HELPER" "$@"; }

# ── Copy to clipboard (cross-platform) ──
clip() {
  if command -v pbcopy &>/dev/null; then
    echo -n "$1" | pbcopy
  elif command -v xclip &>/dev/null; then
    echo -n "$1" | xclip -selection clipboard
  elif command -v xsel &>/dev/null; then
    echo -n "$1" | xsel --clipboard
  fi
}

# ── Step 1: Fetch meetings via MCP (triggers OAuth browser sign-in once) ──
info "Connecting to Granola..."
meetings_json="$(granola_mcp list --limit "$LIMIT")" \
  || fail "Could not list meetings. If sign-in failed, run: node \"$HELPER\" logout && yeet"
ok "Granola connected"

# ── Step 2: GitHub auth check (gist backend only) ──
if [[ "$BACKEND" == "gist" ]]; then
  if ! gh auth status &>/dev/null 2>&1; then
    info "Not logged into GitHub CLI. Running gh auth login..."
    gh auth login
    gh auth status &>/dev/null 2>&1 || fail "GitHub authentication failed."
  fi
  ok "GitHub authenticated"
fi

# ── Step 3: Interactive meeting picker ──
lines=$(echo "$meetings_json" | python3 -c "
import json, sys
items = json.load(sys.stdin)
for m in items:
    mid = m.get('id', '???')
    title = (m.get('title') or 'Untitled')[:90]
    date = (m.get('date') or '')[:16]
    print(f'{mid}\t{date}\t{title}')
") || fail "Failed to parse meeting list."

[ -z "$lines" ] && fail "No meetings found (free plan shows only the last 30 days)."

selected=$(echo "$lines" \
  | fzf --prompt="Select meeting › " \
        --header="Date              Title" \
        --delimiter=$'\t' \
        --with-nth=2,3 \
        --tabstop=18 \
        --height=40% \
        --reverse \
        --border \
        --ansi) || exit 0

meeting_id=$(echo "$selected" | cut -f1)
meeting_title=$(echo "$selected" | cut -f3)

[ -z "$meeting_id" ] && fail "No meeting selected."
ok "Selected: ${meeting_title}"

# ── Step 3b: Choose what to publish (only if not set via flag/env) ──
if [[ "$CONTENT_SET" -eq 0 ]] && [ -t 1 ]; then
  # col 1 = value (returned), col 2 = label (the only column fzf shows)
  choice=$(printf '%s\t%s\n' \
    "notes"      "Notes & AI summary" \
    "transcript" "Transcript (premium feature only)" \
    | fzf --prompt="Publish what? › " \
          --delimiter=$'\t' --with-nth=2 \
          --height=20% --reverse --border) || exit 0
  CONTENT="${choice%%$'\t'*}"
fi

# ── Step 4: Fetch content (transcript or notes) via MCP ──
tmpfile="/tmp/yeet-${meeting_id}.md"
rc=0
if [[ "$CONTENT" == "notes" ]]; then
  info "Fetching meeting notes + summary..."
  granola_mcp notes "$meeting_id" > "$tmpfile" || rc=$?
else
  info "Fetching transcript..."
  granola_mcp transcript "$meeting_id" > "$tmpfile" || rc=$?
  if [[ $rc -eq 3 ]]; then
    rm -f "$tmpfile"
    fail "This transcript requires a paid Granola plan (transcripts are paid-only over MCP).
    Re-run with ${bold}yeet --notes${reset} to publish the meeting notes + AI summary instead."
  fi
fi
[[ $rc -ne 0 ]] && { rm -f "$tmpfile"; fail "Failed to fetch ${CONTENT} for $meeting_id"; }
[ ! -s "$tmpfile" ] && { rm -f "$tmpfile"; fail "Fetched ${CONTENT} is empty."; }

# ── Step 5: Publish via selected backend ──
url=""

if [[ "$BACKEND" == "gist" ]]; then
  info "Publishing to GitHub Gist..."
  filename="call-${meeting_id}.md"
  gist_output=$(gh gist create "$tmpfile" \
    --desc "Meeting ${CONTENT}: ${meeting_title}" \
    --filename "$filename" \
    2>&1) || fail "Gist creation failed: $gist_output"
  url=$(echo "$gist_output" | grep -oE 'https?://[^ ]+' | head -1)
else
  info "Publishing to Jotbird..."
  jotbird_output=$(jotbird publish "$tmpfile" 2>&1) \
    || fail "Jotbird publish failed: $jotbird_output"
  url=$(echo "$jotbird_output" | grep -oE 'https?://[^ ]+' | head -1)
fi

# ── Step 6: Show URL + copy to clipboard ──
rm -f "$tmpfile"

if [ -n "$url" ]; then
  clip "$url"
  echo ""
  ok "Yeeted ${CONTENT} via ${BACKEND}! URL copied to clipboard:"
  printf "   ${bold}${cyan}%s${reset}\n\n" "$url"
else
  fail "Published but couldn't extract URL from output."
fi
